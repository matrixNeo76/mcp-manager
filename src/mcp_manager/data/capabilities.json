{
  "_meta": {
    "description": "Built-in capabilities of pi / Craft Agents OSS. MCP servers that duplicate these are redundant.",
    "version": "1.0",
    "source": "craft-agents-oss packages/session-tools-core + packages/pi-agent-server + packages/server-core"
  },
  "categories": {
