      "label": "Filesystem",
      "builtin_tools": ["read", "write", "edit", "grep", "find", "ls"],
      "replaces_mcp_keywords": [
        "filesystem", "file system", "file_system", "read file", "write file",
        "directory", "folder", "fs access", "file ops", "file operation",
        "list files", "edit file", "read directory"
      ],
      "replaces_mcp_name_patterns": [
        "filesystem", "fileops", "fs-", "-fs-", "file-system"
      ],
      "redundant_examples": [
        "io.github.bytedance/mcp-server-filesystem",
        "io.github.Digital-Defiance/mcp-filesystem"
      ]
    },
